// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===== User & Profile =====
model User {
  id           String   @id @default(cuid())
  displayName  String
  rankTitle    String   @default("Endeavorer")
  level        Int      @default(42) // derived from total skill points (floor(total/1000))
  avatarUrl    String?
  premium      Boolean  @default(false) // premium subscription toggle
  streakDays   Int      @default(42)
  completionRate Int    @default(84)
  topPercent   Int      @default(5)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  attributes   Attribute[]
  habits       Habit[]
  userMissions UserMission[]
  posts        Post[]
  comments     Comment[]
  postLikes    PostLike[]
}

// ===== Skills (6 mission-driven + 1 habit-driven "Постоянство") =====
model Attribute {
  id        String @id @default(cuid())
  userId    String
  key       String // discipline | social | mental | physical | financial | appearance | consistency
  label     String
  icon      String // material symbol name
  color     String // hex color
  source    String @default("missions") // "missions" | "habits"
  points    Int    @default(0) // accumulated skill points
  sortOrder Int

  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

// ===== Habits =====
// Habits give points ONLY to the 7th skill (consistency / "Постоянство")
model Habit {
  id          String   @id @default(cuid())
  userId      String
  title       String
  category    String   // physical | mental | social | financial | discipline | appearance
  color       String   // hex accent
  target      String   // e.g. "мин. 2д/н", "мин. 7.5ч"
  completed   Boolean  @default(false)
  streak      Int      @default(0)
  weekStart   String   // ISO date of week start "YYYY-MM-DD"
  rewardPoints Int     @default(0) // points awarded to the consistency skill
  subtasksTotal Int @default(0)
  subtasksDone  Int @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ===== User mission instances (stages + timers) =====
// Mission templates are static (see src/lib/mission-templates.ts).
// A UserMission tracks a user's progress through a template's 3 stages.
model UserMission {
  id            String    @id @default(cuid())
  userId        String
  templateId    String
  category      String
  currentStage  Int       @default(0) // 0 = not started, 1/2/3 = stage in progress
  stageStartedAt DateTime? // when the current stage timer started
  completedAt   DateTime?
  // When the NEXT mission in this category becomes available.
  // For premium users = completedAt (instant). For non-premium = completedAt + 7 days.
  nextAvailableAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, templateId])
}

// ===== Community =====
model Post {
  id          String   @id @default(cuid())
  authorId    String
  authorName  String
  authorAvatarUrl String?
  authorBadge String   // e.g. "Подписатель II", "Новичок I"
  category    String   // physical | mental | social | advice | ...
  categoryLabel String // "ФИЗИЧЕСКОЕ РАЗВИТИЕ"
  xpReward    Int      @default(0)
  title       String
  body        String
  likes       Int      @default(0)
  commentsCount Int    @default(0)
  isAdvice    Boolean  @default(false)
  createdAt   DateTime @default(now())

  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments    Comment[]
  likesRel    PostLike[]
}

model Comment {
  id        String @id @default(cuid())
  postId    String
  authorId  String?
  authorName String
  body      String
  createdAt DateTime @default(now())

  post      Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User? @relation(fields: [authorId], references: [id])
}

model PostLike {
  id     String @id @default(cuid())
  postId String
  userId String

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}
