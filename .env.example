# ===== Nevergiveup — Environment Variables =====
# Скопируйте этот файл в .env и заполните значениями

# База данных (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# NextAuth (сгенерируйте: openssl rand -base64 32)
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# Авторизация (false = включить вход/регистрацию, true = bypass для тестов)
NEXT_PUBLIC_AUTH_BYPASS=false

# Cron защита (любая случайная строка)
CRON_SECRET=your-cron-secret

# Push уведомления (сгенерируйте: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=your-public-key
VAPID_PRIVATE_KEY=your-private-key
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-public-key

# Google Analytics (опционально)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
